{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "front/src/env.d.ts",
    "front/src/**/*",
    "front/src/**/*.tsx",
    "electron/preload/*.d.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["front/src/*"],
      "@shared/*": ["shared/*"]
    }
  }
}
